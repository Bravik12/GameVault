<Window x:Class="GameVault.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GameVault"
        xmlns:converters="clr-namespace:GameVault.Converters"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    
    <Window.Resources>
        <converters:BooleanInverseConverter x:Key="BooleanInverseConverter"/>
    </Window.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <TextBlock
                Text="GameVault"
                Grid.Row="0"
                FontSize="24"
                FontWeight="Bold"
                Margin="10"/>
        <StackPanel
            Grid.Row="1"
            Orientation="Horizontal"
            Margin="10">

            <Button 
                x:Name="AddGameButton"
                Content="Add Game" 
                Width="100" 
                Height="30"
                Click="AddGameButton_Click"/>
            
            <Button 
                x:Name="EditGameButton"
                Content="Edit Game" 
                Width="100" 
                Height="30"
                Margin="10,0,0,0"
                Click="EditGameButton_Click"/>
            
            <Button 
                x:Name="DeleteGameButton"
                Content="Delete Game" 
                Width="100" 
                Height="30"
                Margin="420,0,0,0"
                Click="DeleteGameButton_Click"/>
        </StackPanel>
        
        <Grid Grid.Row="2">

            <DataGrid
                
                Margin="10"
                AutoGenerateColumns="False"
                ItemsSource="{Binding Games}"
                SelectedItem="{Binding SelectedGame}"
                CanUserAddRows="False">

                <DataGrid.Columns>
                    <DataGridTextColumn
                        Header="Name"
                        Binding="{Binding Name}"/>
                
                    <DataGridTextColumn
                        Header="Genre"
                        Binding="{Binding Genre}"/>
                
                    <DataGridTextColumn
                        Header="Status"
                        Binding="{Binding Status}"/>
                
                    <DataGridTextColumn
                        Header="Rating"
                        Binding="{Binding Rating}"/>
                
                    <DataGridTextColumn
                        Header="Playtime"
                        Binding="{Binding PlaytimeHours}"/>
                
                </DataGrid.Columns>
                
            </DataGrid>

            <TextBlock
                Text="No games in your library"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                FontSize="16"
                Visibility="{Binding HasGames, Converter={StaticResource BooleanInverseConverter}}"/>
        </Grid>
    </Grid>
</Window>
