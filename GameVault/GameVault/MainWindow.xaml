<Window x:Class="GameVault.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GameVault"
        xmlns:converters="clr-namespace:GameVault.Converters"
        xmlns:views="clr-namespace:GameVault.Views"
        xmlns:vwp="clr-namespace:WpfToolkit.Controls;assembly=VirtualizingWrapPanel"
        mc:Ignorable="d"
        Title="GameVault" Height="600" Width="1000"
        MinHeight="500" MinWidth="800"
        Background="#0D0B14">

    <Window.Resources>
        <converters:BooleanInverseConverter x:Key="BooleanInverseConverter"/>
        <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
        <converters:GameStatusToBrushConverter x:Key="GameStatusToBrushConverter"/>
        <converters:PercentToGridLengthConverter x:Key="PercentToGridLengthConverter"/>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

        <!--  ================= PALETTE ================= -->
        <SolidColorBrush x:Key="BgDeepest"   Color="#0A0912"/>
        <SolidColorBrush x:Key="BgPanel"     Color="#141225"/>
        <SolidColorBrush x:Key="BgPanelAlt"  Color="#191733"/>
        <SolidColorBrush x:Key="BgRow"       Color="#16142A"/>
        <SolidColorBrush x:Key="BgRowAlt"    Color="#1B1836"/>
        <SolidColorBrush x:Key="BorderSubtle" Color="#2A2748"/>
        <SolidColorBrush x:Key="AccentPurple" Color="#7C4DFF"/>
        <SolidColorBrush x:Key="AccentPurpleDark" Color="#5B2FBF"/>
        <SolidColorBrush x:Key="AccentBlue"   Color="#3A6FF7"/>
        <SolidColorBrush x:Key="TextPrimary"  Color="#F1EFFB"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#9C97BE"/>
        <SolidColorBrush x:Key="TextMuted"    Color="#635E85"/>
        <SolidColorBrush x:Key="DangerRed"    Color="#E5484D"/>
        <SolidColorBrush x:Key="DangerRedDark" Color="#A13236"/>

        <LinearGradientBrush x:Key="HeaderGradient" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#0A0912" Offset="0"/>
            <GradientStop Color="#1C1440" Offset="0.55"/>
            <GradientStop Color="#2A1750" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="AccentGradient" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#7C4DFF" Offset="0"/>
            <GradientStop Color="#3A6FF7" Offset="1"/>
        </LinearGradientBrush>

        <!--  ================= BUTTON STYLES ================= -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentGradient}"/>
            <Setter Property="Foreground" Value="#0A0912"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.7"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#2A2748"/>
                                <Setter Property="Foreground" Value="#635E85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{x:Null}">
            <Setter Property="Background" Value="#191733"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderSubtle}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource AccentPurple}"/>
                                <Setter TargetName="border" Property="Background" Value="#221F42"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#4A4670"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#211F3A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  ================= TEXTBOX ================= -->
        <Style x:Key="SearchBox" TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource BgPanelAlt}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="CaretBrush" Value="{StaticResource AccentPurple}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderSubtle}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource AccentPurple}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  ================= COMBOBOX ================= -->
        <Style x:Key="FilterCombo" TargetType="ComboBox">
            <Setter Property="Background" Value="{StaticResource BgPanelAlt}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderSubtle}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleBtn"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="{StaticResource BgPanelAlt}"
                                                BorderBrush="{StaticResource BorderSubtle}"
                                                BorderThickness="1"
                                                CornerRadius="6">
                                            <Grid Margin="10,0,8,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="&#9662;"
                                                           Grid.Column="1"
                                                           Foreground="{StaticResource AccentPurple}"
                                                           VerticalAlignment="Center"
                                                           FontSize="10"/>
                                            </Grid>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter Margin="10,0,26,0"
                                              VerticalAlignment="Center"
                                              IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"/>
                            <Popup x:Name="Popup"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Fade">
                                <Border Background="{StaticResource BgPanelAlt}"
                                        BorderBrush="{StaticResource AccentPurple}"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Margin="0,4,0,0"
                                        MinWidth="{TemplateBinding ActualWidth}">
                                    <ScrollViewer MaxHeight="200">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="{StaticResource AccentPurpleDark}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!--  ================= GAME TILE ================= -->
        <Style x:Key="GameTileItem" TargetType="ListBoxItem">
            <Setter Property="Margin" Value="0,0,16,16"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="TileBorder"
                                Width="210"
                                Height="340"
                                CornerRadius="10"
                                Background="{StaticResource BgPanel}"
                                BorderBrush="{StaticResource BorderSubtle}"
                                BorderThickness="1"
                                ClipToBounds="True">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TileBorder" Property="BorderBrush" Value="{StaticResource AccentPurple}"/>
                                <Setter TargetName="TileBorder" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#7C4DFF" BlurRadius="20" ShadowDepth="0" Opacity="0.55"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TileBorder" Property="BorderBrush" Value="{StaticResource AccentPurple}"/>
                                <Setter TargetName="TileBorder" Property="Background" Value="{StaticResource BgPanelAlt}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding NeedsInstall}" Value="True">
                    <Setter Property="Opacity" Value="0.5"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!--  ================= LIST CHIPS ================= -->
        <Style x:Key="ListChipButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource BgPanelAlt}"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{StaticResource BorderSubtle}"
                                BorderThickness="1"
                                CornerRadius="15">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource AccentPurple}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AllListChip" TargetType="Button" BasedOn="{StaticResource ListChipButton}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding SelectedGameList}" Value="{x:Null}">
                    <Setter Property="Background" Value="{StaticResource AccentGradient}"/>
                    <Setter Property="Foreground" Value="#0A0912"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="GameListChip" TargetType="ListBoxItem">
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="chipBorder"
                                Height="30"
                                CornerRadius="15"
                                Padding="14,0"
                                Background="{StaticResource BgPanelAlt}"
                                BorderBrush="{StaticResource BorderSubtle}"
                                BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="chipBorder" Property="BorderBrush" Value="{StaticResource AccentPurple}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="chipBorder" Property="Background" Value="{StaticResource AccentGradient}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StatusBadge" TargetType="Border">
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="8,2"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
        </Style>

        <Style x:Key="InstalledOnlyToggle" TargetType="ToggleButton">
            <Setter Property="Background" Value="{StaticResource BgPanelAlt}"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{StaticResource BorderSubtle}"
                                BorderThickness="1"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource AccentPurple}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource AccentGradient}"/>
                                <Setter Property="Foreground" Value="#0A0912"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  ================= SCROLLBAR ================= -->
        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="8"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="{StaticResource BorderSubtle}"
                                                        CornerRadius="4"
                                                        Margin="1,0"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand" Opacity="0">
                                        <RepeatButton.Template>
                                            <ControlTemplate>
                                                <Border Background="Transparent"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand" Opacity="0">
                                        <RepeatButton.Template>
                                            <ControlTemplate>
                                                <Border Background="Transparent"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!--  ============ HEADER ============ -->
        <Border Grid.Row="0" Background="{StaticResource HeaderGradient}">
            <Grid>
                <Grid Margin="20,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="42" Height="42"
                                CornerRadius="12"
                                Background="{StaticResource AccentGradient}"
                                Margin="0,0,14,0">
                            <Border.Effect>
                                <DropShadowEffect Color="#7C4DFF" BlurRadius="18" ShadowDepth="0" Opacity="0.6"/>
                            </Border.Effect>
                            <TextBlock Text="&#127918;"
                                       FontSize="20"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="GameVault"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource AccentGradient}"/>
                            <TextBlock Text="Your personal game library"
                                       FontSize="11"
                                       Foreground="{StaticResource TextSecondary}"/>
                        </StackPanel>
                    </StackPanel>

                    <Button Grid.Column="1"
                            Content="&#9881;"
                            Width="30"
                            Height="30"
                            VerticalAlignment="Center"
                            Style="{StaticResource SecondaryButton}"
                            Click="SettingsButton_Click"/>
                </Grid>

                <Border Height="2"
                        VerticalAlignment="Bottom"
                        Background="{StaticResource AccentGradient}"
                        Opacity="0.6"/>
            </Grid>
        </Border>

        <!--  ============ TOOLBAR ============ -->
        <Border Grid.Row="1"
                Background="{StaticResource BgPanel}"
                BorderBrush="{StaticResource BorderSubtle}"
                BorderThickness="0,0,0,1">
            <Grid Margin="20,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Button x:Name="AddGameButton"
                            Content="+ Add Game"
                            Width="110"
                            Height="34"
                            Style="{StaticResource PrimaryButton}"
                            Click="AddGameButton_Click"/>


                    <Button Content="Sync Steam"
                            Click="ImportSteamButton_Click"
                            Margin="8,0,0,0"
                            Width="100"
                            Style="{StaticResource SecondaryButton}"/>
                </StackPanel>

                <TextBox x:Name="SearchTextBox"
                         Grid.Column="2"
                         Height="34"
                         Margin="0,0,10,0"
                         Style="{StaticResource SearchBox}"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Tag="Search your library..."/>

                <ComboBox x:Name="SortComboBox"
                          Grid.Column="3"
                          Width="170"
                          Height="34"
                          Margin="0,0,10,0"
                          Style="{StaticResource FilterCombo}"
                          ItemsSource="{Binding AvailableSortOptions}"
                          SelectedItem="{Binding SelectedSortOption}"/>

                <ComboBox x:Name="FilterComboBox"
                          Grid.Column="4"
                          Width="140"
                          Height="34"
                          Margin="0,0,10,0"
                          Style="{StaticResource FilterCombo}"
                          ItemsSource="{Binding AvailableStatuses}"
                          SelectedItem="{Binding SelectedStatus}"/>

                <ToggleButton x:Name="InstalledOnlyToggle"
                              Grid.Column="5"
                              Content="&#11015; Installed only"
                              Height="34"
                              Style="{StaticResource InstalledOnlyToggle}"
                              IsChecked="{Binding ShowInstalledOnly}"/>
            </Grid>
        </Border>

        <!--  ============ LIST TABS ============ -->
        <Border Grid.Row="2"
                Background="{StaticResource BgPanel}"
                BorderBrush="{StaticResource BorderSubtle}"
                BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Margin="20,10">
                <Button x:Name="AllListsButton"
                        Content="All"
                        MinWidth="70"
                        Style="{StaticResource AllListChip}"
                        Click="AllListsButton_Click"
                        Margin="0,0,8,0"/>

                <ListBox x:Name="GameListsBox"
                         Background="Transparent"
                         BorderThickness="0"
                         ItemsSource="{Binding GameLists}"
                         SelectedItem="{Binding SelectedGameList}"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Disabled"
                         ItemContainerStyle="{StaticResource GameListChip}">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Name}" FontSize="12" FontWeight="SemiBold">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="True">
                                                <Setter Property="Foreground" Value="#0A0912"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <Button Content="&#10133;"
                        Width="34"
                        Style="{StaticResource ListChipButton}"
                        Click="AddListButton_Click"
                        Margin="8,0,0,0"/>
            </StackPanel>
        </Border>

        <!--  ============ GAME LIST ============ -->
        <Grid Grid.Row="3" Background="{StaticResource BgDeepest}">
            <ListBox x:Name="GamesListBox"
                         Margin="20"
                         Background="Transparent"
                         BorderThickness="0"
                         ItemsSource="{Binding GamesView}"
                         SelectedItem="{Binding SelectedGame}"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         ScrollViewer.CanContentScroll="True"
                         VirtualizingPanel.IsVirtualizing="True"
                         VirtualizingPanel.VirtualizationMode="Recycling"
                         VirtualizingPanel.ScrollUnit="Pixel"
                         ItemContainerStyle="{StaticResource GameTileItem}"
                         SelectionChanged="GamesListBox_SelectionChanged">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <vwp:VirtualizingWrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="140"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0"
                                        Background="{StaticResource BgPanelAlt}">
                                    <Grid>
                                        <Image Source="{Binding SteamImageUrl}"
                                               Stretch="UniformToFill"
                                               Visibility="{Binding SteamImageUrl, Converter={StaticResource StringToVisibilityConverter}}"/>

                                        <TextBlock Text="&#127918;"
                                                   FontSize="34"
                                                   Opacity="0.35"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Visibility="{Binding SteamImageUrl, Converter={StaticResource StringToVisibilityConverter}, ConverterParameter=Invert}"/>
                                    </Grid>
                                </Border>

                                <StackPanel Grid.Row="1" Margin="12,10,12,12">
                                    <TextBlock Text="{Binding Name}"
                                               FontWeight="SemiBold"
                                               FontSize="14"
                                               Foreground="{StaticResource TextPrimary}"
                                               TextTrimming="CharacterEllipsis"/>

                                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                        <Border Style="{StaticResource StatusBadge}"
                                                Background="{Binding Status, Converter={StaticResource GameStatusToBrushConverter}}">
                                            <TextBlock Text="{Binding Status}"
                                                       FontSize="10"
                                                       FontWeight="SemiBold"
                                                       Foreground="#0A0912"/>
                                        </Border>

                                        <Border Style="{StaticResource StatusBadge}"
                                                Background="{StaticResource BgPanelAlt}"
                                                BorderBrush="{StaticResource BorderSubtle}"
                                                BorderThickness="1"
                                                Margin="6,0,0,0"
                                                Visibility="{Binding NeedsInstall, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <TextBlock Text="&#11015; Install"
                                                       FontSize="9"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextSecondary}"/>
                                        </Border>
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                        <TextBlock Text="{Binding Rating, StringFormat='&#9733; {0}'}"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource AccentPurple}"/>

                                        <TextBlock Text="{Binding PlaytimeHours, StringFormat='{}{0:0.#} h played'}"
                                                   FontSize="11"
                                                   Foreground="{StaticResource TextMuted}"
                                                   Margin="10,0,0,0"/>
                                    </StackPanel>

                                    <StackPanel Margin="0,12,0,0">
                                        <Border Height="6"
                                                CornerRadius="3"
                                                Background="{StaticResource BgDeepest}"
                                                ClipToBounds="True">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="{Binding AchievementsPercent, Converter={StaticResource PercentToGridLengthConverter}}"/>
                                                    <ColumnDefinition Width="{Binding AchievementsPercent, Converter={StaticResource PercentToGridLengthConverter}, ConverterParameter=Remainder}"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Column="0" CornerRadius="3" Background="{StaticResource AccentGradient}"/>
                                            </Grid>
                                        </Border>

                                        <TextBlock Text="{Binding AchievementsDisplay}"
                                                   FontSize="10"
                                                   Foreground="{StaticResource TextMuted}"
                                                   Margin="0,4,0,0"/>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
            </ListBox>

            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Visibility="{Binding HasGames, Converter={StaticResource BooleanInverseConverter}}">
                <TextBlock Text="&#127918;"
                           FontSize="40"
                           HorizontalAlignment="Center"
                           Opacity="0.4"
                           Margin="0,0,0,10"/>
                <TextBlock Text="No games in your library"
                           HorizontalAlignment="Center"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimary}"/>
                <TextBlock Text="Click &quot;Add Game&quot; to start building your collection"
                           HorizontalAlignment="Center"
                           FontSize="12"
                           Foreground="{StaticResource TextMuted}"
                           Margin="0,4,0,0"/>
            </StackPanel>

            <!--  ============ DETAIL PANEL OVERLAY ============ -->
            <Border x:Name="DetailOverlay"
                    Background="#B0000000"
                    Visibility="Collapsed"
                    Opacity="0"
                    MouseDown="DetailOverlay_MouseDown"/>

            <Border x:Name="DetailPanelHost"
                    Width="380"
                    HorizontalAlignment="Right"
                    Background="{StaticResource BgDeepest}"
                    BorderBrush="{StaticResource BorderSubtle}"
                    BorderThickness="1,0,0,0">
                <Border.RenderTransform>
                    <TranslateTransform x:Name="DetailPanelTransform" X="380"/>
                </Border.RenderTransform>
                <views:GameDetailPanel x:Name="DetailPanel"/>
            </Border>
        </Grid>

        <!--  ============ FOOTER / STATUS BAR ============ -->
        <Border Grid.Row="4"
                Background="{StaticResource BgPanel}"
                BorderBrush="{StaticResource BorderSubtle}"
                BorderThickness="0,1,0,0">
            <TextBlock Margin="20,8"
                       Foreground="{StaticResource TextMuted}"
                       FontSize="11"
                       Text="{Binding GamesView.Count, StringFormat='{}{0} games in library'}"/>
        </Border>
    </Grid>
</Window>
