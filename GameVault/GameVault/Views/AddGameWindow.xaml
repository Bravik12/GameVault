<Window x:Class="GameVault.Views.AddGameWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="clr-namespace:GameVault.Models"
        xmlns:converters="clr-namespace:GameVault.Converters"
        mc:Ignorable="d"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Title="Add Game" Height="450" Width="500">

    <Window.Resources>
        <converters:BooleanInverseConverter x:Key="BooleanInverseConverter"/>
    </Window.Resources>

    <Grid Margin="15">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock
            Grid.Row="0"
            Grid.Column="0"
            Text="Name:"
            VerticalAlignment="Center"
            Margin="0,0,10,10"/>
        
        <TextBox
            Grid.Row="0"
            Grid.Column="1"
            Margin="0,0,0,10"
            Text="{Binding Name}"/>

        <TextBlock
            Grid.Row="1"
            Grid.Column="0"
            Text="Genre:"
            VerticalAlignment="Center"
            Margin="0,0,10,10"/>

        <TextBox
            Grid.Row="1"
            Grid.Column="1"
            Margin="0,0,0,10"
            Text="{Binding Genre}"/>     

        <TextBlock
            Grid.Row="2"
            Grid.Column="0"
            Text="Status:"
            VerticalAlignment="Center"
            Margin="0,0,10,10"/>

        <ComboBox
            Grid.Row="2"
            Grid.Column="1"
            Margin="0,0,0,10"
            ItemsSource="{Binding AvailableStatuses}"
            SelectedItem="{Binding Status}"/>

        <TextBlock
            Grid.Row="3"
            Grid.Column="0"
            Text="Rating:"
            VerticalAlignment="Center"
            Margin="0,0,10,10"/>

        <StackPanel
            Grid.Row="3"
            Grid.Column="1"
            Orientation="Horizontal">

            <CheckBox
                Content="Not Rated"
                IsChecked="{Binding IsNotRated}"
                Margin="0,0,10,0"/>

            <Slider
                x:Name="RatingSlider"
                Minimum="1"
                Maximum="10"
                Value="{Binding Rating}"
                TickFrequency="0.25"
                IsSnapToTickEnabled="True"
                Width="280"
                IsEnabled="{Binding IsNotRated, Converter={StaticResource BooleanInverseConverter}}"/>

            <TextBlock
                Text="{Binding Rating}"
                Margin="0,0,10,0"/>
        </StackPanel>



        <TextBlock
            Grid.Row="4"
            Grid.Column="0"
            Text="Playtime:"
            VerticalAlignment="Center"
            Margin="0,0,10,10"/>

        <TextBox
            Grid.Row="4"
            Grid.Column="1"
            Margin="0,0,0,10"/>

        <TextBlock
            Grid.Row="5"
            Grid.Column="0"
            Text="Notes:"
            VerticalAlignment="Top"
            Margin="0,0,10,10"/>

        <TextBox
            Grid.Row="5"
            Grid.Column="1"
            AcceptsReturn="True"
            TextWrapping="Wrap"
            Text="{Binding Notes}"/>
        
        <Button
            Grid.Row="6"
            Grid.Column="1"
            Content="Add Game"
            Width="100"
            Height="30"
            HorizontalAlignment="Right"
            Margin="0,10,0,0"/>
    </Grid>
    
</Window>
