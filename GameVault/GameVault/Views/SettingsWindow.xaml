<Window x:Class="GameVault.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings"
        Height="400"
        Width="400">

    <StackPanel Margin="20">

        <TextBlock Text="Steam ID"
                   Margin="0,0,0,5"/>

        <TextBox x:Name="SteamIdTextBox"
                 Height="30"/>

        <TextBlock Text="Steam Web API Key"
                   Margin="0,15,0,5"/>

        <TextBox x:Name="SteamApiKeyTextBox"
                 Height="30"/>


        <Button Content="Save"
                Height="35"
                Margin="0,20,0,0"
                Click="SaveButton_Click"/>

    </StackPanel>

</Window>